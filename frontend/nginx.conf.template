server {
    listen 80;

    root /usr/share/nginx/html;
    index index.html;

    # defer upstream DNS to request time so nginx starts even if backend is down
    resolver 127.0.0.11 valid=30s ipv6=off;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /api/ {
        set $upstream http://${BACKEND_HOST}:${BACKEND_PORT};
        proxy_pass $upstream;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }
}
